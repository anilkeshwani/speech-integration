{
    // ty handles the language server; 
    // auto-set by the extension but being explicit for consistency
    "python.languageServer": "None",
    // Point Python extension to uv-managed venv
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    // Ruff as the sole formatter
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "always",
            "source.organizeImports.ruff": "always"
        }
    },
    // Disable Pylance/pylint since ty owns diagnostics
    "python.analysis.ignore": [
        "*"
    ],
    "pylint.enabled": false,
    // ty settings
    "ty.importStrategy": "fromEnvironment", // use your uv venv, not bundled ty
}